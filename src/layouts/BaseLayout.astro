---
import '../styles/global.css';
import '../styles/utilities.css';
import SponsorBar from '../components/SponsorBar.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The World\'s Premier Renal Combat Organization. Two Men Enter. One Man Pisses Blood.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
  <meta name="base-url" content={import.meta.env.BASE_URL} />
  <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}images/logos/favicon.png`} />
  <title>{title} | KPL - Kidney Punch League</title>
</head>
<body>
  <SponsorBar />
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
