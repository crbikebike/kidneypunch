---
import { nextEvent } from '../data/events';
---

<section class="section">
  <div class="container">
    <h2 class="section-title">UPCOMING <span class="text-primary">FIGHT CARD</span></h2>
    <div class="event-card">
      <div class="event-card-header">
        <div class="event-card-title">{nextEvent.name}</div>
        <div class="event-card-badge">{nextEvent.badge}</div>
      </div>

      {nextEvent.matchups.map(m => (
        <div class="matchup">
          <div class="matchup-fighter">
            <div class="matchup-label">{m.label1}</div>
            {m.fighter1.toUpperCase()}
            <div class="matchup-odds">{m.odds1}</div>
          </div>
          <div class="matchup-vs">VS</div>
          <div class="matchup-fighter right">
            <div class="matchup-label">{m.label2}</div>
            {m.fighter2.toUpperCase()}
            <div class="matchup-odds">{m.odds2}</div>
          </div>
        </div>
      ))}

      <div class="prop-bet">
        <strong>SPECIAL PROP</strong> — {nextEvent.propBet.text}&nbsp;
        <strong>{nextEvent.propBet.yes}</strong>&nbsp;/&nbsp;<strong>{nextEvent.propBet.no}</strong>
        &nbsp;&nbsp;<em>via {nextEvent.propBet.via}</em>
      </div>
      <div class="event-card-sponsor">Odds powered by {nextEvent.oddsProvider}</div>
    </div>
  </div>
</section>

<style>
  .event-card {
    background: var(--color-surface);
    border-left: 4px solid var(--color-primary);
    border-radius: var(--border-radius);
    padding: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .event-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .event-card-title {
    font-family: var(--font-display);
    font-size: 1.8rem;
    letter-spacing: 0.05em;
  }

  .event-card-badge {
    font-size: 0.65rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    border: 1px solid var(--color-accent);
    padding: 0.25rem 0.75rem;
    border-radius: var(--border-radius);
  }

  .matchup {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .matchup:last-of-type { border-bottom: none; }

  .matchup-fighter {
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: 0.03em;
  }

  .matchup-fighter.right { text-align: right; }

  .matchup-vs {
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--color-primary);
    padding: 0 1rem;
  }

  .matchup-label {
    font-family: var(--font-body);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 0.25rem;
  }

  .matchup-odds {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-accent);
  }

  .prop-bet {
    background: var(--color-surface-alt);
    padding: 1rem;
    margin-top: 1.5rem;
    border-radius: var(--border-radius);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  .prop-bet strong { color: var(--color-accent); }

  .event-card-sponsor {
    text-align: right;
    font-size: 0.65rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-top: 1rem;
  }

  .section-title {
    text-align: center;
    margin-bottom: 2rem;
  }

  @media (max-width: 768px) {
    .matchup { grid-template-columns: 1fr; text-align: center; gap: 0.25rem; }
    .matchup-fighter.right { text-align: center; }
  }
</style>
