---
interface Props {
  name: string;
  nickname: string;
  record: string;
  kdr: number;
  boi: number;
  quote: string;
  bio: string;
  id: string;
  image: string;
}

const base = import.meta.env.BASE_URL;
const { name, nickname, record, kdr, boi, quote, bio, id, image } = Astro.props;
---

<section class="section section-alt">
  <div class="container">
    <div class="spotlight">
      <div class="spotlight-image">
        <img src={`${base}${image.replace(/^\//, '')}`} alt={name} />
      </div>
      <div>
        <div class="spotlight-badge">FIGHTER OF THE MONTH</div>
        <div class="spotlight-nickname">"{nickname}"</div>
        <div class="spotlight-name">{name.toUpperCase()}</div>
        <div class="spotlight-stats">
          <div>
            <div class="spotlight-stat-value">{record}</div>
            <div class="spotlight-stat-label">Record</div>
          </div>
          <div>
            <div class="spotlight-stat-value">{kdr}</div>
            <div class="spotlight-stat-label">KDR</div>
          </div>
          <div>
            <div class="spotlight-stat-value">{boi}</div>
            <div class="spotlight-stat-label">BOI</div>
          </div>
        </div>
        <div class="spotlight-quote">"{quote}"</div>
        <div class="spotlight-bio">{bio}</div>
        <a href={`${base}fighters/${id}/`} class="btn btn-primary">VIEW FULL PROFILE</a>
      </div>
    </div>
  </div>
</section>

<style>
  .section-alt { background: var(--color-surface-alt); }

  .spotlight {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .spotlight-image {
    background: linear-gradient(135deg, #1A1A1A 0%, #111 100%);
    aspect-ratio: 3/4;
    border-radius: var(--border-radius);
    overflow: hidden;
    position: relative;
  }

  .spotlight-image::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 4px;
    background: var(--color-primary);
    z-index: 1;
  }

  .spotlight-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .spotlight-badge {
    font-family: var(--font-display);
    font-size: 0.8rem;
    color: var(--color-accent);
    letter-spacing: 0.15em;
    margin-bottom: 0.5rem;
  }

  .spotlight-nickname {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .spotlight-name {
    font-family: var(--font-display);
    font-size: 2.5rem;
    letter-spacing: 0.03em;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .spotlight-stats {
    display: flex;
    gap: 2rem;
    margin-bottom: 1rem;
  }

  .spotlight-stat-value {
    font-family: var(--font-display);
    font-size: 1.5rem;
  }

  .spotlight-stat-label {
    font-size: 0.6rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .spotlight-quote {
    font-style: italic;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    border-left: 3px solid var(--color-primary);
    padding-left: 1rem;
    margin: 1rem 0;
  }

  .spotlight-bio {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .spotlight { grid-template-columns: 1fr; }
  }
</style>
